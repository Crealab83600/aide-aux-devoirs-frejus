            <h2 class="section-title">Tarifs</h2>
            <p class="section-subtitle">Des forfaits adaptés à vos besoins</p>

            <div class="pricing-toggle">
                <span class="toggle-label">Particulier</span>
                <input type="checkbox" id="toggle" class="toggle-input">
                <label for="toggle" class="toggle-btn"></label>
                <span class="toggle-label">Forfaits</span>
            </div>

            <div class="pricing-cards">
                <div class="pricing-card">
                    <h3 class="pricing-title">Collège</h3>
                    <div class="pricing-price">
                        <span class="price-amount">15€</span>
                        <span class="price-period">/heure</span>
                    </div>
                    <ul class="pricing-features">
                        <li>Toutes matières</li>
                        <li>Préparation brevet</li>
                        <li>Méthodologie</li>
                        <li>Suivi par email</li>
                    </ul>
                    <a href="#contact" class="btn btn-outline">Choisir</a>
                </div>

                <div class="pricing-card featured">
                    <div class="popular-badge">Populaire</div>
                    <h3 class="pricing-title">Lycée</h3>
                    <div class="pricing-price">
                        <span class="price-amount">20€</span>
                        <span class="price-period">/heure</span>
                    </div>
                    <ul class="pricing-features">
                        <li>Toutes filières</li>
                        <li>Préparation bac</li>
                        <li>Approche personnalisée</li>
                        <li>Support en ligne</li>
                    </ul>
                    <a href="#contact" class="btn btn-primary">Choisir</a>
                </div>

                <div class="pricing-card">
                    <h3 class="pricing-title">Programmation</h3>
                    <div class="pricing-price">
                        <span class="price-amount">25€</span>
                        <span class="price-period">/heure</span>
                    </div>
                    <ul class="pricing-features">
                        <li>Python</li>
                        <li>Arduino</li>
                        <li>Projets pratiques</li>
                        <li>Ressources exclusives</li>
                    </ul>
                    <a href="#contact" class="btn btn-outline">Choisir</a>
                </div>
            </div>
        </div>
