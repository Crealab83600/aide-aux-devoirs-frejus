            <h2 class="section-title">Témoignages</h2>
            <p class="section-subtitle">Ce que disent mes élèves et leurs parents</p>

            <div class="testimonials-slider">
                <div class="testimonial">
                    <div class="testimonial-header">
                        <img src="https://via.placeholder.com/80x80" alt="Avis client" class="testimonial-img">
                        <div class="testimonial-info">
                            <h4 class="testimonial-name">Sophie M.</h4>
                            <span class="testimonial-role">Parent d'élève</span>
