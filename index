    <!-- Section Services -->
    <section id="services" class="services">
        <div class="container">
            <h2 class="section-title">Mes Services</h2>
            <p class="section-subtitle">Soutien scolaire adapté à chaque niveau et besoin</p>

            <div class="services-grid">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-book"></i>
                    </div>
                    <h3 class="service-title">Aide aux devoirs</h3>
                    <p class="service-desc">Soutien scolaire pour toutes les matières du collège et lycée avec méthodologie personnalisée</p>
                    <ul class="service-features">
                        <li>Suivi régulier</li>
                        <li>Préparation aux examens</li>
                        <li>Méthodes de travail</li>
                    </ul>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-code"></i>
                    </div>
                    <h3 class="service-title">Cours de Programmation</h3>
                    <p class="service-desc">Apprentissage du Python et Arduino pour débutants et projets pratiques</p>
                    <ul class="service-features">
                        <li>Python</li>
                        <li>Arduino</li>
                        <li>Projets concrets</li>
                    </ul>
                </div>

                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h3 class="service-title">Préparation Examens</h3>
                    <p class="service-desc">Préparation intensive pour le brevet et le baccalauréat toutes filières</p>
                    <ul class="service-features">
                        <li>Fiches de révision</li>
                        <li>Annales corrigées</li>
                        <li>Techniques d'examen</li>
                    </ul>
                </div>
            </div>
        </div>
