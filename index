<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aide aux devoirs Fréjus | Raphaël Maury</title>
<meta name="description" content="Aide aux devoirs à Fréjus - Primaire au Lycée - Spécialité Python et Arduino">
<link rel="stylesheet" href="style.css">
</head>

<body>

<header class="hero">
    <div class="logo">
        <img src="images/logo.png" alt="Logo RM Tutorat">
        <h1>RM Tutorat</h1>
    </div>
    <p>Aide aux devoirs à Fréjus • Python • Arduino</p>
</header>

<section class="info">
    <h2>🕒 Horaires</h2>
    <ul class="schedule">
        <li>Mercredi : 14h – 18h</li>
        <li>Samedi : 10h – 18h</li>
        <li>Dimanche : 14h – 18h</li>
    </ul>
</section>

<section class="reservation">
    <h2>📅 Réservation</h2>
    <form onsubmit="sendMail(event)">
        <input type="text" id="name" placeholder="Nom élève" required>
        <input type="email" id="email" placeholder="Email parent" required>
        <select id="level">
            <option>Primaire</option>
            <option>Collège</option>
            <option>Lycée</option>
            <option>Python</option>
            <option>Arduino</option>
        </select>
        <button type="submit">Envoyer la demande</button>
    </form>
</section>

<section class="counter-section">
    <h2>🟢 Élèves accompagnés</h2>
    <div class="counter" id="animatedCount">0</div>
</section>

<section id="adminLogin" class="admin-login">
    <h2>🔒 Admin</h2>
    <input type="password" id="password" placeholder="Mot de passe admin">
    <button onclick="login()">Connexion</button>
</section>

<section id="adminPanel" class="hidden admin-panel">
    <h2>Dashboard Admin</h2>
    <p>Modifier nombre d'élèves :</p>
    <input type="number" id="newCount">
    <button onclick="updateCount()">Mettre à jour</button>
</section>

<footer>
    <p>📍 Fréjus</p>
    <p>📧 raphaelmaury83600@gmail.com</p>
    <p>© 2026 Raphaël Maury</p>
</footer>

<script>
let studentCount = 0;

// Animation compteur
function animateCounter(target) {
    const el = document.getElementById("animatedCount");
    let current = 0;
    const increment = Math.ceil(target / 50);
    const interval = setInterval(() => {
        current += increment;
        if(current >= target) {
            current = target;
            clearInterval(interval);
        }
        el.innerText = current;
    }, 30);
}

// Formulaire mail
function sendMail(event) {
    event.preventDefault();
    const name = document.getElementById("name").value;
    const email = document.getElementById("email").value;
    const level = document.getElementById("level").value;
    const subject = "Demande aide aux devoirs";
    const body = `Nom: ${name}%0D%0ANiveau: ${level}%0D%0AEmail: ${email}`;
    window.location.href = `mailto:raphaelmaury83600@gmail.com?subject=${subject}&body=${body}`;
}

// Admin login
function login() {
    const pass = document.getElementById("password").value;
    if(pass === "Raphael83600") {
        document.getElementById("adminPanel").classList.remove("hidden");
        alert("Connecté !");
    } else {
        alert("Mot de passe incorrect");
    }
}

// Update compteur depuis admin
function updateCount() {
    studentCount = document.getElementById("newCount").value;
    animateCounter(studentCount);
}

// Init compteur animé à 0
animateCounter(studentCount);
</script>

</body>
</html>
