                        <li><i class="fas fa-envelope"></i> raphaelmaury83600@gmail.com</li>
                        <li><i class="fas fa-phone"></i> 06 12 34 56 78</li>
                        <li><i class="fas fa-map-marker-alt"></i> Fréjus, France</li>
                    </ul>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
