    <!-- Section Hero -->
    <section id="accueil" class="hero">
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">Cours Particuliers & Aide aux Devoirs à Fréjus</h1>
                <p class="hero-subtitle">Élève en première proposant un soutien scolaire personnalisé en mathématiques, français, sciences et programmation</p>
                <div class="hero-buttons">
                    <a href="#contact" class="btn btn-primary">Prendre RDV</a>
                    <a href="#services" class="btn btn-outline">Découvrir</a>
                </div>
                <div class="hero-stats">
                    <div class="stat-item">
                        <span class="stat-number">50+</span>
                        <span class="stat-text">Élèves accompagnés</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">95%</span>
                        <span class="stat-text">Satisfaction</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">3</span>
                        <span class="stat-text">Années d'expérience</span>
                    </div>
                </div>
            </div>
        </div>
