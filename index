<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aide aux devoirs Fréjus | Raphaël Maury</title>
<meta name="description" content="Aide aux devoirs à Fréjus - Primaire au Lycée - Spécialité Python et Arduino">
<link rel="stylesheet" href="style.css">
</head>

<body>

<header class="hero">
    <h1>Aide aux devoirs à Fréjus</h1>
    <p>Primaire • Collège • Lycée • Python • Arduino</p>
    <a href="#reservation" class="btn">Réserver une séance</a>
</header>

<section>
    <h2>🎯 Pourquoi me choisir ?</h2>
    <div class="grid">
        <div class="card">
            <h3>📚 Toutes matières</h3>
            <p>Du primaire au lycée.</p>
        </div>

        <div class="card">
            <h3>💻 Spécialité codage</h3>
            <p>Python & Arduino.</p>
        </div>

        <div class="card">
            <h3>📈 Progression suivie</h3>
            <p>Méthode claire et efficace.</p>
        </div>
    </div>
</section>

<section>
    <h2>🕒 Horaires</h2>
    <ul class="schedule">
        <li>Mercredi : 14h – 18h</li>
        <li>Samedi : 10h – 18h</li>
        <li>Dimanche : 14h – 18h</li>
    </ul>
</section>

<section id="reservation">
    <h2>📅 Réservation en ligne</h2>
    <p>Remplissez le formulaire pour réserver votre séance.</p>

    <iframe 
        src="TON_LIEN_GOOGLE_FORM" 
        width="100%" 
        height="600" 
        frameborder="0">
    </iframe>
</section>

<section>
    <h2>📊 Élèves accompagnés</h2>
    <div class="counter">
        <span id="count">0</span> élèves
    </div>
</section>

<section>
    <h2>💳 Paiement en ligne (bientôt)</h2>
    <p>Le paiement sécurisé sera disponible prochainement avec accord parental.</p>
</section>

<section class="admin">
    <h2>🔒 Dashboard Admin (Privé)</h2>
    <p>Total élèves actuels :</p>
    <input type="number" id="adminInput" placeholder="Entrer nombre d'élèves">
    <button onclick="updateCounter()">Mettre à jour</button>
</section>

<footer>
    <p>📍 Fréjus</p>
    <p>📧 raphaelmaury83600@gmail.com</p>
    <p>© 2026 Raphaël Maury</p>
</footer>

<script>
let currentCount = 0;

function updateCounter() {
    const value = document.getElementById("adminInput").value;
    if(value >= 0) {
        currentCount = value;
        document.getElementById("count").innerText = currentCount;
    }
}
</script>

</body>
</html>
